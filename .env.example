# Oracle DB replica (downstream of GoldenGate)
ORACLE_DSN=localhost:1521/ORCL
ORACLE_USER=mcp_reader
ORACLE_PASSWORD=              # required — no default; must be set explicitly
ORACLE_POOL_MIN=2
ORACLE_POOL_MAX=10

# Anthropic (for score/classify tools — not needed in Phase 1)
ANTHROPIC_API_KEY=sk-ant-...

# Kafka (optional — leave empty to disable)
KAFKA_BROKERS=
KAFKA_CONSUMER_GROUP=goldengate-mcp

# Write-back REST endpoint (optional — leave empty to disable)
WRITEBACK_BASE_URL=
WRITEBACK_API_KEY=
WRITEBACK_TIMEOUT_SECONDS=10.0

# Circuit breaker
CIRCUIT_BREAKER_WRITE_LIMIT=100
CIRCUIT_BREAKER_RESET_SECONDS=60

# RBAC role lists (comma-separated)
RBAC_READ_ROLES=analyst,auditor,agent-read
RBAC_SCORE_ROLES=analyst,agent-score
RBAC_WRITE_ROLES=compliance-officer,agent-write
RBAC_STRICT=false

# Audit log: "file" or "oracle"
AUDIT_LOG_MODE=file
AUDIT_LOG_FILE_PATH=audit.log

# Schema map path
SCHEMA_MAP_PATH=src/schema/schema_map.yaml
